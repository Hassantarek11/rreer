rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Reusable Authentication and Ownership Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '') == "hassantareknshshs@gmail.com" ||
        request.auth.token.get('email', '') == "admin@nema.com" || 
        request.auth.token.get('email', '').matches(".*admin.*") ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true)
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 3. Robust Type-Safe Validation Blueprints
    function isValidUser(data) {
      return (!data.keys().hasAll(['displayName']) || data.displayName is string)
        && (!data.keys().hasAll(['nemaCompleted']) || data.nemaCompleted is bool)
        && (!data.keys().hasAll(['isAdmin']) || data.isAdmin is bool)
        && (!data.keys().hasAll(['telegram']) || (
             data.telegram is map
             && (!data.telegram.keys().hasAll(['botToken']) || data.telegram.botToken is string)
             && (!data.telegram.keys().hasAll(['chatId']) || data.telegram.chatId is string)
             && (!data.telegram.keys().hasAll(['reminderTime']) || data.telegram.reminderTime is string)
             && (!data.telegram.keys().hasAll(['enabled']) || data.telegram.enabled is bool)
           ));
    }

    function isValidTask(data) {
      return (!data.keys().hasAll(['id']) || data.id is string)
        && (!data.keys().hasAll(['day']) || data.day is string)
        && (!data.keys().hasAll(['subject']) || data.subject is string)
        && (!data.keys().hasAll(['time']) || data.time is string)
        && (!data.keys().hasAll(['duration']) || data.duration is int || data.duration is number)
        && (!data.keys().hasAll(['notes']) || data.notes is string)
        && (!data.keys().hasAll(['completed']) || data.completed is bool);
    }

    function isValidLesson(data) {
      return (!data.keys().hasAll(['id']) || data.id is string)
        && (!data.keys().hasAll(['day']) || data.day is string)
        && (!data.keys().hasAll(['subject']) || data.subject is string)
        && (!data.keys().hasAll(['time']) || data.time is string)
        && (!data.keys().hasAll(['location']) || data.location is string)
        && (!data.keys().hasAll(['teacherName']) || data.teacherName is string)
        && (!data.keys().hasAll(['notes']) || data.notes is string);
    }

    function isValidNotificationSignal(data) {
      return (!data.keys().hasAll(['id']) || data.id is string)
        && (!data.keys().hasAll(['title']) || data.title is string)
        && (!data.keys().hasAll(['body']) || data.body is string)
        && (!data.keys().hasAll(['createdAt']) || data.createdAt is int || data.createdAt is number)
        && (!data.keys().hasAll(['senderDeviceId']) || data.senderDeviceId is string);
    }

    // 4. Match Blocks for Paths
    match /admins/{adminId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
      allow delete: if isOwner(userId) || isAdmin();

      match /tasks/{taskId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if (isOwner(userId) || isAdmin()) && isValidId(taskId) && isValidTask(request.resource.data);
        allow update: if (isOwner(userId) || isAdmin()) && isValidId(taskId) && isValidTask(request.resource.data);
        allow delete: if (isOwner(userId) || isAdmin()) && isValidId(taskId);
      }

      match /lessons/{lessonId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if (isOwner(userId) || isAdmin()) && isValidId(lessonId) && isValidLesson(request.resource.data);
        allow update: if (isOwner(userId) || isAdmin()) && isValidId(lessonId) && isValidLesson(request.resource.data);
        allow delete: if (isOwner(userId) || isAdmin()) && isValidId(lessonId);
      }

      match /notifications_signal/{notificationId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create, update: if (isOwner(userId) || isAdmin()) && isValidId(notificationId) && isValidNotificationSignal(request.resource.data);
        allow delete: if (isOwner(userId) || isAdmin()) && isValidId(notificationId);
      }
    }
  }
}
